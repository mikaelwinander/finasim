rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Lock down everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow users to perform CRUD operations ONLY on their own subcollections
    match /users/{userId} {
      // Optional: Allow the user to manage their own top-level profile doc
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow the user to manage their own datasets metadata
      match /datasets/{datasetId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
  }
}